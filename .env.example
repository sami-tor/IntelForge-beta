# Local development environment template.
# Copy to .env.local and fill with real values. Never commit real secrets.

OPENSEARCH_URL=http://127.0.0.1:9200
OPENSEARCH_INDEX=file_index
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INSECURE=false
OPENSEARCH_FIELD_CONTENT=Content
OPENSEARCH_FIELD_FILEPATH=FilePath
OPENSEARCH_FIELD_FILENAME=FileName
OPENSEARCH_FIELD_LINENUM=LineNum
OPENSEARCH_FIELD_FILETYPE=fileType

DATABASE_URL=

JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
RESPONSE_SIGNING_SECRET=
CRON_SECRET=

PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

QUICKWIT_URL=http://localhost:7280
VISUAL_SEARCH_SERVICE_URL=http://localhost:8000
VISUAL_SEARCH_API_KEY=
VISUAL_SEARCH_ALLOWED_ORIGINS=http://localhost:3000
VISUAL_SEARCH_ALLOWED_PATH_ROOT=/data

MILVUS_HOST=localhost
MILVUS_PORT=19530
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PUBLIC_URL=http://localhost:9000/intelforge-images

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ================================================
# Intel Hub - Optional Free API Keys
# All feeds work without these, but adding keys
# unlocks more sources in IOC lookup
# ================================================

# VirusTotal (free: 500 req/day) - https://www.virustotal.com/gui/sign-in
# Unlocks: IP, domain, hash, URL lookups
VIRUSTOTAL_API_KEY=

# AbuseIPDB (free: 1000 checks/day) - https://www.abuseipdb.com/register
# Unlocks: IP abuse confidence scores
ABUSEIPDB_API_KEY=

# GreyNoise Community (free tier) - https://www.greynoise.io/viz/signup
# Unlocks: Mass-scanner / noise classification for IPs
GREYNOISE_API_KEY=

# AlienVault OTX (free) - https://otx.alienvault.com/api/
# Unlocks: OTX pulse feeds and indicator lookup
OTX_API_KEY=

# Hybrid Analysis (free) - https://www.hybrid-analysis.com/signup
# Unlocks: Deep malware sandbox lookup
HYBRID_API_KEY=

# HaveIBeenPwned (paid) - https://haveibeenpwned.com/API/Key
# Unlocks: Breach monitor / email check
HIBP_API_KEY=
